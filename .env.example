# ============================================
# PPTAgent 环境变量配置
# ============================================
# 复制本文件为 .env, 填入你自己的 API 密钥
# ⚠️ 警告: 绝不要把 .env 提交到 git!
#
# 获取密钥:
# - Tavily: https://tavily.com (Agent-friendly search, 默认引擎)
# - Serper: https://serper.dev (Google Search proxy, 兜底)

TAVILY_API_KEY=replace-with-your-tavily-key
SERPER_API_KEY=replace-with-your-own-serper-key

# 可选: Sub-Agent 调用的 LLM (Phase 1 Skill 在 Claude Code 内运行时不需要)
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_WIRE_API=anthropic
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
# Optional exact pricing for model gateway aliases, in USD per 1M tokens.
# ANTHROPIC_MODEL_PRICING_INPUT=
# ANTHROPIC_MODEL_PRICING_OUTPUT=
# OPENAI_API_KEY=
# DASHSCOPE_API_KEY=
